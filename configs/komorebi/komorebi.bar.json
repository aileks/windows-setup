{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.bar.json",
  "monitor": 0,
  "height": 30,
  "font_family": "JetBrainsMono Nerd Font Propo",
  "font_size": 12,
  "icon_scale": 1.2,
  "padding": 4,
  "theme": {
    "palette": "Custom",
    "colours": {
      "base_00": { "r": 18, "g": 18, "b": 18 },
      "base_01": { "r": 25, "g": 25, "b": 25 },
      "base_02": { "r": 33, "g": 33, "b": 33 },
      "base_03": { "r": 83, "g": 83, "b": 83 },
      "base_04": { "r": 148, "g": 148, "b": 148 },
      "base_05": { "r": 167, "g": 167, "b": 167 },
      "base_06": { "r": 180, "g": 180, "b": 180 },
      "base_07": { "r": 213, "g": 213, "b": 213 },
      "base_08": { "r": 177, "g": 66, "b": 66 },
      "base_09": { "r": 74, "g": 139, "b": 139 },
      "base_0a": { "r": 196, "g": 105, "b": 61 },
      "base_0b": { "r": 223, "g": 100, "b": 100 },
      "base_0c": { "r": 228, "g": 154, "b": 68 },
      "base_0d": { "r": 216, "g": 124, "b": 74 },
      "base_0e": { "r": 177, "g": 66, "b": 66 },
      "base_0f": { "r": 137, "g": 73, "b": 42 }
    },
    "accent": "Base0D"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": { "enable": true, "hide_empty_workspaces": false },
        "layout": { "enable": true },
        "focused_window": { "enable": true, "show_icon": true }
      }
    }
  ],
  "center_widgets": [{ "Media": { "enable": true } }],
  "right_widgets": [
    { "Cpu": { "enable": true } },
    { "Memory": { "enable": true } },
    { "Network": { "enable": true, "show_activity": true, "show_total_activity": false } },
    { "Date": { "enable": true, "format": "MonthDateYear" } },
    { "Time": { "enable": true, "format": "TwentyFourHour" } }
  ]
}
